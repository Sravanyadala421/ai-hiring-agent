# LLM Provider Configuration
# Options: "ollama" or "gemini"
LLM_PROVIDER=gemini

# Default model to use (now using higher-limit models)
# For Ollama: "gemma3:4b", "qwen3:4b", "mistral:7b", etc.
# For Gemini: "gemini-2.0-flash", "gemini-1.5-flash", "gemini-1.5-pro", etc.
DEFAULT_MODEL=gemini-2.0-flash

# Primary Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Additional API Keys for rotation (optional but recommended)
# GEMINI_API_KEY_2=your_second_api_key_here
# GEMINI_API_KEY_3=your_third_api_key_here
# GEMINI_API_KEY_4=your_fourth_api_key_here

# GitHub Token (optional - improves API rate limits)
GITHUB_TOKEN=
